generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// CORE & MULTI-TENANCY
// -----------------------------------------------------------------------------

model Gym {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  address   String?
  phone     String?
  email     String?
  website   String?
  description String? @db.Text
  openingHours Json?
  socialLinks  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  razorpayKeyId     String?
  razorpayKeySecret String?

  ownerId   String   @unique
  owner     User     @relation("GymOwner", fields: [ownerId], references: [id])

  users         User[]         @relation("GymUsers")
  plans         Plan[]
  subscriptions Subscription[]
  payments      Payment[]
  workoutPlans  WorkoutPlan[]  @relation("GymWorkoutPlans")
  dietPlans     DietPlan[]     @relation("GymDietPlans")
  notificationLogs NotificationLog[]
}

// -----------------------------------------------------------------------------
// USERS & ROLES
// -----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  GYM_OWNER
  TRAINER
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gymId     String?
  gym       Gym?     @relation("GymUsers", fields: [gymId], references: [id])
  ownedGym  Gym?     @relation("GymOwner")

  // For members
  subscriptions Subscription[]
  payments      Payment[]
  bookingsAsMember Booking[] @relation("MemberBookings")
  attendances      Attendance[]

  // For trainers
  membersAssigned User[]    @relation("TrainerMembers")
  trainer         User?     @relation("TrainerMembers", fields: [trainerId], references: [id])
  trainerId       String?
  bookingsAsTrainer Booking[] @relation("TrainerBookings")

  // Workout Plans
  createdWorkoutPlans  WorkoutPlan[] @relation("CreatedWorkoutPlans")
  assignedWorkoutPlans MemberWorkoutPlan[] @relation("AssignedWorkoutPlans")

  // Diet Plans
  createdDietPlans     DietPlan[] @relation("CreatedDietPlans")
  assignedDietPlans    MemberDietPlan[] @relation("AssignedDietPlans")

  // Notifications
  notificationLogs     NotificationLog[]
}

// -----------------------------------------------------------------------------
// MEMBERSHIP & SUBSCRIPTION
// -----------------------------------------------------------------------------

model Plan {
  id        String   @id @default(cuid())
  name      String
  price     Float
  duration  Int      // Duration in days
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  planId     String
  plan       Plan     @relation(fields: [planId], references: [id])
  gymId      String
  gym        Gym      @relation(fields: [gymId], references: [id])
  
  startDate  DateTime
  endDate    DateTime
  autoRenew  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payments Payment[]
  notificationLogs NotificationLog[]
}

// -----------------------------------------------------------------------------
// PAYMENTS
// -----------------------------------------------------------------------------

enum PaymentMethod {
  CARD
  CASH
  PAYPAL
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id             String         @id @default(cuid())
  amount         Float
  paymentMethod  PaymentMethod
  status         PaymentStatus  @default(PENDING)
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  gymId          String
  gym            Gym            @relation(fields: [gymId], references: [id])
  createdAt      DateTime       @default(now())

  // Razorpay Specific Fields
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?     @unique
  razorpaySignature String?
}

// -----------------------------------------------------------------------------
// TRAINER / ATTENDANCE / BOOKINGS
// -----------------------------------------------------------------------------

model Booking {
  id        String   @id @default(cuid())
  timeSlot  DateTime
  trainerId String
  trainer   User     @relation("TrainerBookings", fields: [trainerId], references: [id])
  memberId  String
  member    User     @relation("MemberBookings", fields: [memberId], references: [id])
  status    String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  createdAt DateTime @default(now())
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
}

// -----------------------------------------------------------------------------
// ENUMS FOR WORKOUT PLANS
// -----------------------------------------------------------------------------
enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutGoal {
  FAT_LOSS
  MUSCLE_GAIN
  STRENGTH
  GENERAL_FITNESS
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// -----------------------------------------------------------------------------
// WORKOUT PLAN MODULE
// -----------------------------------------------------------------------------
model WorkoutPlan {
  id          String          @id @default(cuid())
  name        String
  description String?         @db.Text
  difficulty  DifficultyLevel
  goal        WorkoutGoal
  duration    Int             // Duration in days
  
  gymId       String
  gym         Gym             @relation("GymWorkoutPlans", fields: [gymId], references: [id], onDelete: Cascade)
  
  creatorId   String
  creator     User            @relation("CreatedWorkoutPlans", fields: [creatorId], references: [id])
  
  days        WorkoutDay[]
  assignments MemberWorkoutPlan[]
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([gymId])
  @@index([creatorId])
}

model WorkoutDay {
  id            String      @id @default(cuid())
  dayNumber     Int         // e.g., 1, 2, 3
  title         String?     // e.g., "Leg Day", "Push"
  notes         String?     @db.Text
  
  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  
  exercises     Exercise[]

  @@index([workoutPlanId])
}

model Exercise {
  id           String     @id @default(cuid())
  name         String
  sets         Int
  reps         String     // String for flexibility (e.g., "10-12", "To failure")
  restTime     Int        // Rest time in seconds
  notes        String?    @db.Text
  order        Int        // Sorting order
  
  workoutDayId String
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  @@index([workoutDayId])
}

model MemberWorkoutPlan {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation("AssignedWorkoutPlans", fields: [userId], references: [id], onDelete: Cascade)
  
  workoutPlanId  String
  workoutPlan    WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  
  startDate      DateTime
  endDate        DateTime?
  status         PlanStatus  @default(ACTIVE)
  progress       Float       @default(0.0) // Progress percentage 0-100
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([workoutPlanId])
}

// -----------------------------------------------------------------------------
// DIET PLAN MODULE
// -----------------------------------------------------------------------------

enum DietGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model DietPlan {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  goal          DietGoal
  totalCalories Int
  
  gymId         String
  gym           Gym      @relation("GymDietPlans", fields: [gymId], references: [id], onDelete: Cascade)
  
  creatorId     String
  creator       User     @relation("CreatedDietPlans", fields: [creatorId], references: [id])
  
  meals         DietMeal[]
  assignments   MemberDietPlan[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([gymId])
  @@index([creatorId])
}

model DietMeal {
  id          String   @id @default(cuid())
  mealType    MealType
  time        String?  // e.g., "08:00 AM"
  
  dietPlanId  String
  dietPlan    DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  
  foodItems   FoodItem[]

  @@index([dietPlanId])
}

model FoodItem {
  id          String   @id @default(cuid())
  name        String
  protein     Float
  carbs       Float
  fats        Float
  calories    Float
  
  dietMealId  String
  dietMeal    DietMeal @relation(fields: [dietMealId], references: [id], onDelete: Cascade)

  @@index([dietMealId])
}

model MemberDietPlan {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation("AssignedDietPlans", fields: [userId], references: [id], onDelete: Cascade)
  
  dietPlanId  String
  dietPlan    DietPlan   @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  
  startDate   DateTime
  endDate     DateTime?
  status      PlanStatus @default(ACTIVE)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([dietPlanId])
}

// -----------------------------------------------------------------------------
// NOTIFICATIONS / REMINDERS
// -----------------------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

model NotificationLog {
  id             String              @id @default(cuid())
  gymId          String
  gym            Gym                 @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription?       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  channel        NotificationChannel
  message        String              @db.Text
  sentAt         DateTime            @default(now())

  @@index([gymId])
  @@index([userId])
  @@index([subscriptionId])
}

